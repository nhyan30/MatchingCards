--- !u!114 &5481185740574712145
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 138806922784659793}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "GAMEPLAY:\r\n\r\n1. CHARACTER SELECTION\r\n   - Select a character from
    the grid to be your mystery character\r\n   - Your opponent (AI or another player)
    will do the same\r\n\r\n2. ASKING QUESTIONS\r\n   - Take turns asking Yes/No
    questions about the opponent's character\r\n   - Use questions like \"\"Does
    your character have glasses?\"\" or \"\"Does your character have a hat?\"\"\r\n  
    - Navigate through questions using the arrow buttons\r\n   - Press SEND to ask
    the current question\r\n\r\n3. ELIMINATING CHARACTERS\r\n   - Based on the answers,
    characters will be eliminated from your grid\r\n   - Click on a character to
    cross them out manually if needed\r\n\r\n4. MAKING A GUESS\r\n   - When you think
    you know the opponent's character, press \"\"Do A Guess\"\"\r\n   - Click on
    the character you think is the mystery character\r\n   - If correct, you win!
    If wrong, you lose!\r\n\r\nMULTIPLAYER:\r\n   - Host a game to create a room
    with a 6-digit code\r\n   - Share the code with a friend on the same WiFi network\r\n  
    - Join a game by entering the host's room code\r\n\r\nTIPS:\r\n   - Ask questions
    that eliminate the most characters\r\n   - Pay attention to the opponent's questions
    for hints\r\n   - Don't guess too early - make sure you're confident!\""
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 158608b031a9e3740bf2591e8623b9a8, type: 2}
  m_sharedMaterial: {fileID: -171090993086729772, guid: 158608b031a9e3740bf2591e8623b9a8, type: 2}
