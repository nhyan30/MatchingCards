--- !u!114 &7470024815603525086
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8268221264514096390}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dfd0a6c425540dd4497ad7b401413192, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  helpPanel: {fileID: 2822826592079501629}
  cancelButton: {fileID: 605106841084896604}
  helpText: {fileID: 5481185740574712145}
  howToPlayText: "OBJECTIVE:\r\nGuess your opponent's mystery character before they
    guess yours!\r\n\r\nGAMEPLAY:\r\n\r\n1. CHARACTER SELECTION\r\n   - Select a
    character from the grid to be your mystery character\r\n   - Your opponent (AI
    or another player) will do the same\r\n\r\n2. ASKING QUESTIONS\r\n   - Take turns
    asking Yes/No questions about the opponent's character\r\n   - Use questions
    like \"Does your character have glasses?\" or \"Does your character have a hat?\"\r\n  
    - Navigate through questions using the arrow buttons\r\n   - Press SEND to ask
    the current question\r\n\r\n3. ELIMINATING CHARACTERS\r\n   - Based on the answers,
    characters will be eliminated from your grid\r\n   - Click on a character to
    cross them out manually if needed\r\n\r\n4. MAKING A GUESS\r\n   - When you think
    you know the opponent's character, press \"Do A Guess\"\r\n   - Click on the
    character you think is the mystery character\r\n   - If correct, you win! If
    wrong, you lose!\r\n\r\nMULTIPLAYER:\r\n   - Host a game to create a room with
    a 6-digit code\r\n   - Share the code with a friend on the same WiFi network\r\n  
    - Join a game by entering the host's room code\r\n\r\nTIPS:\r\n   - Ask questions
    that eliminate the most characters\r\n   - Pay attention to the opponent's questions
    for hints\r\n   - Don't guess too early - make sure you're confident!"
